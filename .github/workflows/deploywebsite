name: Deploy Astro Site to GitHub Pages

on:
  push:
    branches:
      - main                        # Trigger on push to main branch
    paths:
      - "src/pages/index.astro"     # Only trigger when this file changes
      - "src/**"                    # Or any other source file
      - "public/**"                 # Or public assets
      - "astro.config.*"            # Or Astro config
  workflow_dispatch:                # Allow manual trigger from GitHub UI

# Grant GITHUB_TOKEN permissions to deploy to Pages
permissions:
  contents: read
  pages: write
  id-token: write

# Allow only one concurrent deployment
concurrency:
  group: "pages"
  cancel-in-progress: true

jobs:
  # ─────────────────────────────────────────────
  # Job 1: Build
  # ─────────────────────────────────────────────
  build:
    name: Build Astro Site
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: "20"
          cache: "npm"              # Cache npm deps for faster builds

      - name: Install dependencies
        run: npm ci                 # Clean install — respects package-lock.json

      - name: Setup GitHub Pages
        id: pages
        uses: actions/configure-pages@v4

      - name: Build Astro site
        run: npm run build
        env:
          # Inject the base URL so Astro's <base> tag and asset paths work
          # correctly on GitHub Pages (e.g. /repo-name/)
          SITE: ${{ steps.pages.outputs.origin }}
          BASE_PATH: ${{ steps.pages.outputs.base_path }}

      - name: Upload Pages artifact
        uses: actions/upload-pages-artifact@v3
        with:
          path: ./dist             # Astro's default output directory

  # ─────────────────────────────────────────────
  # Job 2: Deploy (runs only after build succeeds)
  # ─────────────────────────────────────────────
  deploy:
    name: Deploy to GitHub Pages
    runs-on: ubuntu-latest
    needs: build                   # Wait for build job

    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}

    steps:
      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
