---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { href = '#', variant = 'primary', size = 'md', class: className = '' } = Astro.props;
---

{href ? (
  <a {href} class={`button button-${variant} button-${size} ${className}`}>
    <slot />
  </a>
) : (
  <button class={`button button-${variant} button-${size} ${className}`}>
    <slot />
  </button>
)}

<style>
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: var(--font-weight-semibold);
    border-radius: var(--radius-lg);
    border: none;
    cursor: pointer;
    transition: all var(--animation-duration-base) var(--animation-timing);
    text-decoration: none;
  }

  .button-sm {
    padding: var(--spacing-sm) var(--spacing-md);
    font-size: var(--text-sm);
  }

  .button-md {
    padding: var(--spacing-md) var(--spacing-lg);
    font-size: var(--text-base);
  }

  .button-lg {
    padding: var(--spacing-lg) var(--spacing-2xl);
    font-size: var(--text-lg);
  }

  .button-primary {
    background: var(--color-accent);
    color: white;
    box-shadow: 0 4px 15px rgba(6, 182, 212, 0.3);
  }

  .button-primary:hover {
    background: var(--color-accent-light);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(6, 182, 212, 0.5);
  }

  .button-secondary {
    backdrop-filter: blur(var(--glass-blur));
    background: rgba(255, 255, 255, var(--glass-opacity));
    color: var(--color-text);
    border: var(--glass-border);
    box-shadow: var(--glass-shadow);
  }

  .button-secondary:hover {
    background: rgba(255, 255, 255, calc(var(--glass-opacity) + 0.05));
    border-color: rgba(6, 182, 212, 0.3);
    color: var(--color-accent);
  }

  .button-outline {
    background: transparent;
    color: var(--color-accent);
    border: 2px solid var(--color-accent);
  }

  .button-outline:hover {
    background: var(--color-accent);
    color: white;
  }
</style>
