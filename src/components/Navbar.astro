---
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navLinks = [
  { label: 'Home', href: '/BubblesCorpDemo/' },
  { label: 'About', href: '/BubblesCorpDemo/about' },
  { label: 'Services', href: '/BubblesCorpDemo/services' },
  { label: 'Contact', href: '/BubblesCorpDemo/contact' },
];
---

<nav class="navbar" role="navigation" aria-label="Main navigation">
  <div class="navbar-container">
    <div class="navbar-brand">
      <a href="/BubblesCorpDemo/" aria-label="BubbleCorp Home">
        <span class="brand-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="7" width="20" height="14" rx="2" ry="2" />
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
          </svg>
        </span>
        <span class="brand-text">BubbleCorp</span>
      </a>
    </div>

    <button class="navbar-toggle" id="navbar-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <ul class="navbar-menu" id="navbar-menu" role="menubar">
      {navLinks.map(link => (
        <li role="none">
          <a
            href={link.href}
            role="menuitem"
            class={currentPath === link.href ? 'active' : ''}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="cta-button-wrapper" role="none">
        <a href="/BubblesCorpDemo/contact" class="cta-button" role="menuitem">Get Started</a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .navbar {
    background: transparent;
    border-bottom: 1px solid rgba(56, 189, 248, 0.08);
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    backdrop-filter: blur(12px);
    transition: background var(--animation-duration-base) var(--animation-timing);
  }

  .navbar.scrolled {
    background: rgba(9, 14, 26, 0.85);
    border-bottom-color: rgba(56, 189, 248, 0.15);
  }

  .navbar-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: var(--spacing-md) var(--spacing-lg);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .navbar-brand a {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: var(--text-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--animation-duration-base) var(--animation-timing);
  }

  .navbar-brand a:hover {
    color: var(--color-accent);
  }

  .navbar-menu {
    display: flex;
    list-style: none;
    gap: var(--spacing-xl);
    align-items: center;
    margin: 0;
  }

  .navbar-menu a {
    color: var(--color-text-secondary);
    font-weight: var(--font-weight-medium);
    transition: all var(--animation-duration-base) var(--animation-timing);
    position: relative;
    padding: var(--spacing-xs) 0;
    text-decoration: none;
  }

  .navbar-menu a:hover,
  .navbar-menu a.active {
    color: var(--color-accent);
  }

  .navbar-menu a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-secondary));
    border-radius: var(--radius-full);
    transition: width var(--animation-duration-base) var(--animation-timing);
  }

  .navbar-menu a:hover::after,
  .navbar-menu a.active::after {
    width: 100%;
  }

  .cta-button-wrapper {
    margin-left: var(--spacing-lg);
  }

  .cta-button {
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-secondary)) !important;
    color: white !important;
    padding: var(--spacing-sm) var(--spacing-xl) !important;
    border-radius: var(--radius-lg);
    font-weight: var(--font-weight-semibold);
    transition: all var(--animation-duration-base) var(--animation-timing);
    box-shadow: 0 4px 16px var(--color-accent-glow);
    text-decoration: none;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px var(--color-accent-glow);
  }

  .navbar-toggle {
    display: none;
    flex-direction: column;
    background: none;
    border: none;
    cursor: pointer;
    gap: 5px;
    padding: var(--spacing-sm);
  }

  .navbar-toggle span {
    width: 24px;
    height: 2px;
    background: var(--color-text);
    border-radius: var(--radius-full);
    transition: all var(--animation-duration-base) var(--animation-timing);
  }

  @media (max-width: 768px) {
    .navbar-toggle {
      display: flex;
    }

    .navbar-menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: var(--spacing-md);
      padding: var(--spacing-lg);
      background: rgba(9, 14, 26, 0.97);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(56, 189, 248, 0.1);
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.35s ease, padding 0.35s ease;
    }

    .navbar-menu.active {
      max-height: 500px;
      padding: var(--spacing-lg);
    }

    .navbar-menu a {
      display: block;
      padding: var(--spacing-sm) 0;
    }

    .cta-button-wrapper {
      margin-left: 0;
      width: 100%;
    }

    .cta-button {
      display: block;
      text-align: center;
    }

    .navbar-toggle.active span:nth-child(1) {
      transform: rotate(45deg) translate(5px, 5px);
    }

    .navbar-toggle.active span:nth-child(2) {
      opacity: 0;
    }

    .navbar-toggle.active span:nth-child(3) {
      transform: rotate(-45deg) translate(5px, -5px);
    }
  }
</style>

<script>
  const toggle = document.getElementById('navbar-toggle');
  const menu = document.getElementById('navbar-menu');
  const nav = document.querySelector('.navbar');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      toggle.classList.toggle('active');
      menu.classList.toggle('active');
    });

    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        toggle.classList.remove('active');
        menu.classList.remove('active');
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.classList.contains('active')) {
        toggle.setAttribute('aria-expanded', 'false');
        toggle.classList.remove('active');
        menu.classList.remove('active');
      }
    });
  }

  if (nav) {
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 50);
    });
  }
</script>
