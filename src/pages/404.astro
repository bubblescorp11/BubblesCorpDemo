---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
---

<MainLayout title="Page Not Found - BubbleCorp" description="The page you're looking for could not be found.">
  <Navbar />

  <section class="min-h-[60vh] flex items-center py-24">
    <div class="container mx-auto px-6">
      <div class="text-center mb-16">
        <div class="text-8xl font-black mb-4 leading-none text-gradient">404</div>
        <h1 class="text-3xl font-bold mb-4" style="color: var(--color-text);">Page Not Found</h1>
        <p class="text-lg mb-8 max-w-md mx-auto" style="color: var(--color-text-secondary);">Sorry, the page you're looking for doesn't exist or has been moved.</p>
        <div class="flex gap-4 justify-center flex-wrap">
          <Button href="/BubblesCorpDemo/" variant="primary" size="lg">Back to Home</Button>
          <Button href="/BubblesCorpDemo/contact" variant="secondary" size="lg">Contact Support</Button>
        </div>
      </div>

      <div class="max-w-lg mx-auto p-8 rounded-2xl glass-container">
        <h2 class="text-xl font-semibold mb-6" style="color: var(--color-text);">Quick Links</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/BubblesCorpDemo/" class="flex items-center gap-2 p-3 rounded-lg transition-colors hover:bg-white/5" style="color: var(--color-text-secondary);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            Home
          </a>
          <a href="/BubblesCorpDemo/about" class="flex items-center gap-2 p-3 rounded-lg transition-colors hover:bg-white/5" style="color: var(--color-text-secondary);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            About Us
          </a>
          <a href="/BubblesCorpDemo/services" class="flex items-center gap-2 p-3 rounded-lg transition-colors hover:bg-white/5" style="color: var(--color-text-secondary);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            Services
          </a>
          <a href="/BubblesCorpDemo/contact" class="flex items-center gap-2 p-3 rounded-lg transition-colors hover:bg-white/5" style="color: var(--color-text-secondary);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            Contact
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</MainLayout>
