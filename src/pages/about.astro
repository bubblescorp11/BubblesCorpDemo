---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import HeroSection from '../components/HeroSection.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';
import Footer from '../components/Footer.astro';
---

<MainLayout title="About BubbleCorp - SAP Financial Services Experts" description="Learn about BubbleCorp's mission, team, and expertise in SAP Group Reporting and financial services.">
  <Navbar currentPath="/BubblesCorpDemo/about" />

  <HeroSection 
    title="About BubbleCorp"
    subtitle="Our Story"
    description="Leading provider of SAP Group Reporting and financial services solutions"
    ctaText=""
  />

  <!-- Company Overview -->
  <section class="company-overview">
    <div class="container">
      <div class="overview-content">
        <div class="overview-text">
          <h2>Who We Are</h2>
          <p>
            BubbleCorp is a premier financial services firm specializing in SAP Group Reporting solutions. Founded with a vision to transform corporate financial processes, we've been helping organizations streamline their SAP implementations and reporting workflows.
          </p>
          <p>
            Our team brings together industry veterans with deep expertise in SAP systems, financial consolidation, and business intelligence. We're committed to delivering solutions that not only meet but exceed our clients' expectations.
          </p>
          <ul>
            <li>✓ 15+ years of combined SAP expertise</li>
            <li>✓ 50+ successful implementations</li>
            <li>✓ Serving Fortune 500 companies</li>
            <li>✓ ISO 27001 Certified</li>
          </ul>
        </div>
        <div class="overview-stats">
          <Card>
            <div class="stat">
              <div class="stat-number">50+</div>
              <div class="stat-label">Successful Projects</div>
            </div>
          </Card>
          <Card>
            <div class="stat">
              <div class="stat-number">100+</div>
              <div class="stat-label">Enterprise Clients</div>
            </div>
          </Card>
          <Card>
            <div class="stat">
              <div class="stat-number">15+</div>
              <div class="stat-label">Years Experience</div>
            </div>
          </Card>
          <Card>
            <div class="stat">
              <div class="stat-number">24/7</div>
              <div class="stat-label">Support Available</div>
            </div>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Values -->
  <section class="mission-values">
    <div class="container">
      <div class="section-header">
        <h2>Our Mission & Values</h2>
        <p>Guiding principles that drive everything we do</p>
      </div>

      <div class="values-grid">
        <Card>
          <h3>🎯 Mission</h3>
          <p>
            To empower organizations with cutting-edge SAP solutions that drive financial excellence, operational efficiency, and sustainable growth.
          </p>
        </Card>

        <Card>
          <h3>🤝 Excellence</h3>
          <p>
            We pursue excellence in every project, delivering solutions that exceed expectations and create lasting value for our clients.
          </p>
        </Card>

        <Card>
          <h3>🔒 Trust</h3>
          <p>
            Trust is at the heart of our relationships. We maintain the highest standards of integrity and confidentiality in all our engagements.
          </p>
        </Card>

        <Card>
          <h3>💡 Innovation</h3>
          <p>
            We stay ahead of the curve, continuously exploring new technologies and methodologies to provide innovative solutions.
          </p>
        </Card>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="team-section">
    <div class="container">
      <div class="section-header">
        <h2>Our Expert Team</h2>
        <p>Dedicated professionals with deep SAP expertise</p>
      </div>

      <div class="team-grid">
        <Card>
          <div class="team-member">
            <div class="member-avatar">👤</div>
            <h3>John Smith</h3>
            <p class="member-role">Chief Consultant</p>
            <p class="member-bio">20+ years in SAP implementations with expertise in Financial Consolidation.</p>
          </div>
        </Card>

        <Card>
          <div class="team-member">
            <div class="member-avatar">👤</div>
            <h3>Sarah Johnson</h3>
            <p class="member-role">Senior Solutions Architect</p>
            <p class="member-bio">Specializing in SAP Group Reporting and analytics solutions for enterprise clients.</p>
          </div>
        </Card>

        <Card>
          <div class="team-member">
            <div class="member-avatar">👤</div>
            <h3>Michael Chen</h3>
            <p class="member-role">Technical Lead</p>
            <p class="member-bio">Expert in SAP system administration, performance optimization, and infrastructure.</p>
          </div>
        </Card>

        <Card>
          <div class="team-member">
            <div class="member-avatar">👤</div>
            <h3>Emily Rodriguez</h3>
            <p class="member-role">Client Success Manager</p>
            <p class="member-bio">Dedicated to ensuring client satisfaction and long-term partnership success.</p>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Ready to Partner with Us?</h2>
        <p>Let's discuss how we can transform your financial operations with expert SAP solutions.</p>
        <Button href="/contact" variant="primary" size="lg">Contact Our Team</Button>
      </div>
    </div>
  </section>

  <Footer />
</MainLayout>

<style>
  .company-overview {
    padding: var(--spacing-3xl) var(--spacing-md);
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .overview-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-3xl);
    align-items: center;
  }

  .overview-text h2 {
    margin-bottom: var(--spacing-lg);
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .overview-text p {
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--spacing-lg);
  }

  .overview-text ul {
    list-style: none;
    margin: 0;
  }

  .overview-text li {
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
    font-weight: var(--font-weight-medium);
  }

  .overview-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-lg);
  }

  .stat {
    text-align: center;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: var(--font-weight-bold);
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: var(--spacing-sm);
  }

  .stat-label {
    color: var(--color-text-secondary);
    font-weight: var(--font-weight-semibold);
  }

  .mission-values {
    padding: var(--spacing-3xl) var(--spacing-md);
    background: linear-gradient(180deg, transparent 0%, rgba(99, 102, 241, 0.05) 100%);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--spacing-lg);
  }

  .values-grid h3 {
    margin-bottom: var(--spacing-md);
  }

  .values-grid p {
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin: 0;
  }

  .team-section {
    padding: var(--spacing-3xl) var(--spacing-md);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--spacing-lg);
  }

  .team-member {
    text-align: center;
  }

  .member-avatar {
    font-size: 3rem;
    margin-bottom: var(--spacing-md);
  }

  .team-member h3 {
    margin-bottom: var(--spacing-sm);
  }

  .member-role {
    color: var(--color-primary);
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--spacing-md);
  }

  .member-bio {
    color: var(--color-text-secondary);
    margin: 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
  }

  .section-header h2 {
    margin-bottom: var(--spacing-md);
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-header p {
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
  }

  .cta-section {
    padding: var(--spacing-3xl) var(--spacing-md);
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(236, 72, 153, 0.1) 100%);
  }

  .cta-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-content h2 {
    margin-bottom: var(--spacing-lg);
  }

  .cta-content p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-2xl);
  }

  @media (max-width: 768px) {
    .overview-content {
      grid-template-columns: 1fr;
      gap: var(--spacing-2xl);
    }

    .overview-stats {
      grid-template-columns: repeat(2, 1fr);
    }

    .team-grid {
      grid-template-columns: 1fr;
    }

    .company-overview,
    .mission-values,
    .team-section,
    .cta-section {
      padding: var(--spacing-2xl) var(--spacing-md);
    }
  }
</style>
