---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ParallaxHero from '../components/react/ParallaxHero.tsx';
import ScrollRevealSection from '../components/react/ScrollRevealSection.tsx';
import GlowCard from '../components/react/GlowCard.tsx';
import TeamMemberCard from '../components/react/TeamMemberCard.tsx';
import IconFeature from '../components/react/IconFeature.tsx';
import MagneticButton from '../components/react/MagneticButton.tsx';
import { iconTarget, iconShield, iconTrending, iconLightbulb, iconArrow, iconCheck } from '../components/react/icons';
---

<MainLayout title="About BubbleCorp - SAP Financial Services Experts" description="Learn about BubbleCorp's mission, team, and expertise in SAP Group Reporting and financial services.">
  <Navbar currentPath="/BubblesCorpDemo/about" />

  <ParallaxHero
    client:load
    title="About BubbleCorp"
    subtitle="Our Story"
    description="Leading provider of SAP Group Reporting and financial services solutions"
    backgroundImage="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1200&h=600&fit=crop"
  />

  <ScrollRevealSection client:visible variant="default">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-4xl font-bold mb-6" style="color: var(--color-text);">Who We Are</h2>
        <p class="mb-4 leading-relaxed" style="color: var(--color-text-secondary);">
          BubbleCorp is a premier financial services firm specializing in SAP Group Reporting solutions. Founded with a vision to transform corporate financial processes, we've been helping organizations streamline their SAP implementations and reporting workflows.
        </p>
        <p class="mb-6 leading-relaxed" style="color: var(--color-text-secondary);">
          Our team brings together industry veterans with deep expertise in SAP systems, financial consolidation, and business intelligence. We're committed to delivering solutions that not only meet but exceed our clients' expectations.
        </p>
        <ul class="space-y-3" style="list-style: none; padding: 0;">
          <li class="flex items-center gap-3" style="color: var(--color-text-secondary);">
            {iconCheck} 15+ years of combined SAP expertise
          </li>
          <li class="flex items-center gap-3" style="color: var(--color-text-secondary);">
            {iconCheck} 50+ successful implementations
          </li>
          <li class="flex items-center gap-3" style="color: var(--color-text-secondary);">
            {iconCheck} Serving Fortune 500 companies
          </li>
          <li class="flex items-center gap-3" style="color: var(--color-text-secondary);">
            {iconCheck} ISO 27001 Certified
          </li>
        </ul>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <GlowCard client:visible icon={iconTarget} title="50+" description="Successful Projects" delay={0} className="text-center" />
        <GlowCard client:visible icon={iconShield} title="100+" description="Enterprise Clients" delay={0.1} className="text-center" />
        <GlowCard client:visible icon={iconTrending} title="15+" description="Years Experience" delay={0.2} className="text-center" />
        <GlowCard client:visible icon={iconLightbulb} title="24/7" description="Support Available" delay={0.3} className="text-center" />
      </div>
    </div>
  </ScrollRevealSection>

  <ScrollRevealSection client:visible variant="gradient">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold mb-4" style="color: var(--color-text);">Our Mission & Values</h2>
      <p class="text-lg max-w-xl mx-auto" style="color: var(--color-text-secondary);">Guiding principles that drive everything we do</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <IconFeature client:visible icon={iconTarget} title="Mission" description="To empower organizations with cutting-edge SAP solutions that drive financial excellence, operational efficiency, and sustainable growth." delay={0} />
      <IconFeature client:visible icon={iconShield} title="Trust" description="Trust is at the heart of our relationships. We maintain the highest standards of integrity and confidentiality in all our engagements." delay={0.1} />
      <IconFeature client:visible icon={iconTrending} title="Excellence" description="We pursue excellence in every project, delivering solutions that exceed expectations and create lasting value for our clients." delay={0.2} />
      <IconFeature client:visible icon={iconLightbulb} title="Innovation" description="We stay ahead of the curve, continuously exploring new technologies and methodologies to provide innovative solutions." delay={0.3} />
    </div>
  </ScrollRevealSection>

  <ScrollRevealSection client:visible variant="default">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold mb-4" style="color: var(--color-text);">Our Expert Team</h2>
      <p class="text-lg max-w-xl mx-auto" style="color: var(--color-text-secondary);">Dedicated professionals with deep SAP expertise</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <TeamMemberCard client:visible name="John Smith" role="Chief Consultant" bio="20+ years in SAP implementations with expertise in Financial Consolidation." delay={0} />
      <TeamMemberCard client:visible name="Sarah Johnson" role="Senior Solutions Architect" bio="Specializing in SAP Group Reporting and analytics solutions for enterprise clients." delay={0.1} />
      <TeamMemberCard client:visible name="Michael Chen" role="Technical Lead" bio="Expert in SAP system administration, performance optimization, and infrastructure." delay={0.2} />
      <TeamMemberCard client:visible name="Emily Rodriguez" role="Client Success Manager" bio="Dedicated to ensuring client satisfaction and long-term partnership success." delay={0.3} />
    </div>
  </ScrollRevealSection>

  <ScrollRevealSection client:visible variant="glass">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-4xl font-bold mb-4" style="color: var(--color-text);">Ready to Partner with Us?</h2>
      <p class="text-lg mb-8" style="color: var(--color-text-secondary);">Let's discuss how we can transform your financial operations with expert SAP solutions.</p>
      <MagneticButton client:load href="/BubblesCorpDemo/contact" className="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-bold text-white text-lg shadow-lg" style="background:linear-gradient(135deg, var(--color-accent), var(--color-accent-secondary)); box-shadow: 0 4px 24px var(--color-accent-glow);">
        Contact Our Team
        {iconArrow}
      </MagneticButton>
    </div>
  </ScrollRevealSection>

  <Footer />
</MainLayout>
