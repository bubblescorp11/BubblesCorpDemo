---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ParallaxHero from '../components/react/ParallaxHero.tsx';
import ScrollRevealSection from '../components/react/ScrollRevealSection.tsx';
import GlowCard from '../components/react/GlowCard.tsx';
import IconFeature from '../components/react/IconFeature.tsx';
import ContactForm from '../components/ContactForm.tsx';
import { iconMail, iconPhone, iconMapPin, iconClock } from '../components/react/icons';
---

<MainLayout title="Contact BubbleCorp - Get in Touch" description="Contact BubbleCorp for SAP Group Reporting services. Reach out to our team for a consultation.">
  <Navbar currentPath="/BubblesCorpDemo/contact" />

  <ParallaxHero
    client:load
    title="Get in Touch"
    subtitle="Contact Us"
    description="We'd love to hear from you. Let's discuss how we can help transform your SAP strategy."
    backgroundImage="https://images.unsplash.com/photo-1497366216548-37526070297c?w=1200&h=600&fit=crop"
  />

  <ScrollRevealSection client:visible variant="default">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold mb-4" style="color: var(--color-text);">Contact Information</h2>
      <p class="text-lg max-w-xl mx-auto" style="color: var(--color-text-secondary);">Reach out to us through any of these channels. We're here to help!</p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
      <div class="lg:col-span-2 space-y-4">
        <IconFeature client:visible icon={iconMail} title="Email" description="info@bubblecorp.com" delay={0} />
        <IconFeature client:visible icon={iconPhone} title="Phone" description="+1 (555) 123-4567" delay={0.1} />
        <IconFeature client:visible icon={iconMapPin} title="Office" description="123 Financial District Blvd, New York, NY 10001" delay={0.2} />
        <IconFeature client:visible icon={iconClock} title="Business Hours" description="Mon-Fri: 9:00 AM - 6:00 PM" delay={0.3} />
      </div>
      <div class="lg:col-span-3">
        <div class="p-8 rounded-2xl text-center" style="background: rgba(17, 26, 46, 0.7); backdrop-filter: blur(12px); border: 1px solid rgba(56, 189, 248, 0.1);">
          <h2 class="text-2xl font-bold mb-2" style="color: var(--color-text);">Send us a Message</h2>
          <p class="mb-6" style="color: var(--color-text-secondary);">Fill out the form below and we'll get back to you as soon as possible.</p>
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </ScrollRevealSection>

  <ScrollRevealSection client:visible variant="gradient">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold mb-4" style="color: var(--color-text);">Frequently Asked Questions</h2>
      <p class="text-lg max-w-xl mx-auto" style="color: var(--color-text-secondary);">Common questions about our services</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <GlowCard client:visible title="What is SAP Group Reporting?" description="SAP Group Reporting is a solution for financial consolidation and reporting that helps organizations consolidate data from multiple subsidiaries." delay={0} />
      <GlowCard client:visible title="How long does implementation take?" description="Typically 3-6 months based on complexity and scope. We'll provide a detailed timeline during the planning phase." delay={0.1} />
      <GlowCard client:visible title="Do you offer post-implementation support?" description="Yes, we provide comprehensive support including monitoring, maintenance, performance optimization, and user support." delay={0.2} />
      <GlowCard client:visible title="Can you help migrate from legacy systems?" description="Absolutely. We have extensive experience migrating from legacy systems to modern SAP solutions." delay={0.3} />
      <GlowCard client:visible title="What about training for our team?" description="We provide comprehensive training programs tailored to your team's needs, including functional and technical training." delay={0.4} />
      <GlowCard client:visible title="Is your solution scalable?" description="Yes, our solutions are designed to scale with your business from mid-size to enterprise." delay={0.5} />
    </div>
  </ScrollRevealSection>

  <Footer />
</MainLayout>
