---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import HeroSection from '../components/HeroSection.astro';
import ServiceCard from '../components/ServiceCard.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Footer from '../components/Footer.astro';
---

<MainLayout title="BubbleCorp - SAP Group Reporting Services" description="Professional SAP Group Reporting services for financial excellence and business intelligence.">
  <Navbar currentPath="/" />
  
  <HeroSection 
    title="Transform Your SAP Group Reporting"
    subtitle="Professional SAP Solutions"
    description="Comprehensive SAP Group Reporting services tailored to optimize your financial reporting, consolidation, and business intelligence."
    ctaText="Schedule a Demo"
    ctaLink="/BubblesCorpDemo/contact"
  />

  <!-- Why Choose Us Section -->
  <section class="why-choose-us">
    <div class="container">
      <div class="section-header">
        <h2>Why Choose BubbleCorp?</h2>
        <p>Industry expertise, proven solutions, and dedicated support</p>
      </div>

      <div class="features-grid">
        <Card>
          <div class="feature-icon">🎯</div>
          <h3>Expert Implementation</h3>
          <p>Leveraging years of SAP expertise to deliver seamless implementations tailored to your business needs.</p>
        </Card>

        <Card>
          <div class="feature-icon">⚡</div>
          <h3>Fast Deployment</h3>
          <p>Accelerated timelines without compromising quality. Get your SAP systems running efficiently.</p>
        </Card>

        <Card>
          <div class="feature-icon">🛡️</div>
          <h3>Enterprise Security</h3>
          <p>Robust security protocols ensuring your financial data is protected with industry best practices.</p>
        </Card>

        <Card>
          <div class="feature-icon">🤝</div>
          <h3>24/7 Support</h3>
          <p>Dedicated support team available round-the-clock to ensure your systems run smoothly.</p>
        </Card>

        <Card>
          <div class="feature-icon">📈</div>
          <h3>Performance Optimization</h3>
          <p>Continuous monitoring and optimization to maximize your SAP system performance and ROI.</p>
        </Card>

        <Card>
          <div class="feature-icon">🎓</div>
          <h3>Training & Knowledge Transfer</h3>
          <p>Comprehensive training programs ensuring your team masters the systems and tools.</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- Services Preview Section -->
  <section class="services-preview">
    <div class="container">
      <div class="section-header">
        <h2>Our Services</h2>
        <p>Comprehensive SAP Group Reporting solutions for every stage of your journey</p>
      </div>

      <div class="services-grid">
        <ServiceCard 
          icon="🔧"
          title="Implementation"
          description="End-to-end SAP Group Reporting implementation with best practices, data migration, and system configuration."
        />
        <ServiceCard 
          icon="⚙️"
          title="Optimization"
          description="Performance tuning, process optimization, and system enhancement to maximize your investment."
        />
        <ServiceCard 
          icon="📊"
          title="Reporting Solutions"
          description="Advanced reporting, consolidation, and analytics solutions for better business insights."
        />
        <ServiceCard 
          icon="📚"
          title="Training & Support"
          description="Comprehensive training programs and ongoing technical support for your team."
        />
      </div>

      <div class="services-cta">
        <Button href="/BubblesCorpDemo/services" variant="primary" size="lg">Explore All Services</Button>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Ready to Transform Your SAP Strategy?</h2>
        <p>Let's discuss how BubbleCorp can help you achieve your business goals with advanced SAP solutions.</p>
        <Button href="/BubblesCorpDemo/contact" variant="primary" size="lg">Get Started Today</Button>
      </div>
    </div>
  </section>

  <Footer />
</MainLayout>

<style>
  .why-choose-us {
    padding: var(--spacing-3xl) var(--spacing-md);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-xl);
  }

  .feature-icon {
    font-size: 2.5rem;
    margin-bottom: var(--spacing-md);
  }

  .services-preview {
    padding: var(--spacing-3xl) var(--spacing-md);
    background: linear-gradient(180deg, transparent 0%, rgba(99, 102, 241, 0.05) 100%);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-xl);
    margin-bottom: var(--spacing-2xl);
  }

  .services-cta {
    text-align: center;
  }

  .cta-section {
    padding: var(--spacing-3xl) var(--spacing-md);
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(236, 72, 153, 0.1) 100%);
  }

  .cta-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-content h2 {
    margin-bottom: var(--spacing-lg);
  }

  .cta-content p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-2xl);
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
  }

  .section-header h2 {
    margin-bottom: var(--spacing-md);
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-header p {
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    max-width: 600px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .why-choose-us,
    .services-preview,
    .cta-section {
      padding: var(--spacing-2xl) var(--spacing-md);
    }

    .features-grid,
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
