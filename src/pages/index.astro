---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import AnimatedHeroSection from '../components/AnimatedHeroSection.tsx';
import ServiceCard from '../components/ServiceCard.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Footer from '../components/Footer.astro';
import AnimatedCard from '../components/AnimatedCard.tsx';
import AnimatedStats from '../components/AnimatedStats.tsx';
import AnimatedSection from '../components/AnimatedSection.tsx';
---

<MainLayout title="BubbleCorp - SAP Group Reporting Services" description="Professional SAP Group Reporting services for financial excellence and business intelligence.">
  <Navbar currentPath="/BubblesCorpDemo/" />
  
  <AnimatedHeroSection 
    client:load
    title="Transform Your SAP Group Reporting"
    subtitle="Professional SAP Solutions"
    description="Comprehensive SAP Group Reporting services tailored to optimize your financial reporting, consolidation, and business intelligence."
    ctaText="Schedule a Demo"
    ctaLink="/BubblesCorpDemo/contact"
    backgroundImage="https://images.unsplash.com/photo-1633356122544-f134324ef6db?w=1200&h=600&fit=crop"
  />

  <!-- Stats Section -->
  <section class="stats-section">
    <div class="container">
      <AnimatedStats client:load stats={[
        { value: 500, label: "Expert SAP Professionals", suffix: "+" },
        { value: 98, label: "Client Satisfaction Rate", suffix: "%" },
        { value: 15, label: "Years of Excellence", suffix: "+" },
        { value: 100, label: "Successful Implementations", suffix: "+" }
      ]} />
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <AnimatedSection client:load variant="glass" className="why-choose-us">
    <div class="container">
      <div class="section-header">
        <h2>Why Choose BubbleCorp?</h2>
        <p>Industry expertise, proven solutions, and dedicated support</p>
      </div>

      <div class="features-grid">
        <AnimatedCard client:load
          icon="🎯"
          title="Expert Implementation"
          description="Leveraging years of SAP expertise to deliver seamless implementations tailored to your business needs."
          delay={0}
        />

        <AnimatedCard client:load
          icon="⚡"
          title="Fast Deployment"
          description="Accelerated timelines without compromising quality. Get your SAP systems running efficiently."
          delay={0.1}
        />

        <AnimatedCard client:load
          icon="🛡️"
          title="Enterprise Security"
          description="Robust security protocols ensuring your financial data is protected with industry best practices."
          delay={0.2}
        />

        <AnimatedCard client:load
          icon="🤝"
          title="24/7 Support"
          description="Dedicated support team available round-the-clock to ensure your systems run smoothly."
          delay={0.3}
        />

        <AnimatedCard client:load
          icon="📈"
          title="Performance Optimization"
          description="Continuous monitoring and optimization to maximize your SAP system performance and ROI."
          delay={0.4}
        />

        <AnimatedCard client:load
          icon="🎓"
          title="Training & Knowledge Transfer"
          description="Comprehensive training programs ensuring your team masters the systems and tools."
          delay={0.5}
        />
      </div>
    </div>
  </AnimatedSection>

  <!-- Services Preview Section -->
  <AnimatedSection client:load variant="default" className="services-preview">
    <div class="container">
      <div class="section-header">
        <h2>Our Services</h2>
        <p>Comprehensive SAP Group Reporting solutions for every stage of your journey</p>
      </div>

      <div class="services-grid">
        <ServiceCard 
          icon="🔧"
          title="Implementation"
          description="End-to-end SAP Group Reporting implementation with best practices, data migration, and system configuration."
        />
        <ServiceCard 
          icon="⚙️"
          title="Optimization"
          description="Performance tuning, process optimization, and system enhancement to maximize your investment."
        />
        <ServiceCard 
          icon="📊"
          title="Reporting Solutions"
          description="Advanced reporting, consolidation, and analytics solutions for better business insights."
        />
        <ServiceCard 
          icon="📚"
          title="Training & Support"
          description="Comprehensive training programs and ongoing technical support for your team."
        />
      </div>

      <div class="services-cta">
        <Button href="/BubblesCorpDemo/services" variant="primary" size="lg">Explore All Services</Button>
      </div>
    </div>
  </AnimatedSection>

  <!-- CTA Section -->
  <AnimatedSection client:load variant="glass" className="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Ready to Transform Your SAP Strategy?</h2>
        <p>Let's discuss how BubbleCorp can help you achieve your business goals with advanced SAP solutions.</p>
        <Button href="/BubblesCorpDemo/contact" variant="primary" size="lg">Get Started Today</Button>
      </div>
    </div>
  </AnimatedSection>

  <Footer />
</MainLayout>

<style>
  .stats-section {
    padding: var(--spacing-3xl) var(--spacing-md);
    background: linear-gradient(135deg, rgba(30, 58, 138, 0.1) 0%, rgba(6, 182, 212, 0.05) 100%);
  }

  .why-choose-us {
    padding: var(--spacing-3xl) var(--spacing-md);
    background: linear-gradient(135deg, rgba(6, 182, 212, 0.05) 0%, rgba(30, 58, 138, 0.05) 100%);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-xl);
  }

  .services-preview {
    padding: var(--spacing-3xl) var(--spacing-md);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-xl);
    margin-bottom: var(--spacing-2xl);
  }

  .services-cta {
    text-align: center;
  }

  .cta-section {
    padding: var(--spacing-3xl) var(--spacing-md);
    background: linear-gradient(135deg, rgba(6, 182, 212, 0.08) 0%, rgba(30, 58, 138, 0.08) 100%);
  }

  .cta-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-content h2 {
    margin-bottom: var(--spacing-lg);
    color: var(--color-text);
  }

  .cta-content p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-2xl);
  }

  .container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
  }

  .section-header h2 {
    margin-bottom: var(--spacing-md);
    color: var(--color-accent);
    font-size: var(--text-4xl);
  }

  .section-header p {
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    max-width: 600px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .why-choose-us,
    .services-preview,
    .cta-section {
      padding: var(--spacing-2xl) var(--spacing-md);
    }

    .features-grid,
    .services-grid {
      grid-template-columns: 1fr;
    }

    .section-header h2 {
      font-size: var(--text-2xl);
    }
  }
</style>
