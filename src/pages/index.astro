---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ParallaxHero from '../components/react/ParallaxHero.tsx';
import ScrollRevealSection from '../components/react/ScrollRevealSection.tsx';
import GlowCard from '../components/react/GlowCard.tsx';
import AnimatedStats from '../components/AnimatedStats.tsx';
import MagneticButton from '../components/react/MagneticButton.tsx';
import { iconTarget, iconZap, iconShield, iconHandshake, iconTrending, iconGrad, iconWrench, iconSettings, iconBarChart, iconBook } from '../components/react/icons';
---

<MainLayout title="BubbleCorp - SAP Group Reporting Services" description="Professional SAP Group Reporting services for financial excellence and business intelligence.">
  <Navbar currentPath="/BubblesCorpDemo/" />

  <ParallaxHero
    client:load
    title="Transform Your SAP Group Reporting"
    subtitle="Professional SAP Solutions"
    description="Comprehensive SAP Group Reporting services tailored to optimize your financial reporting, consolidation, and business intelligence."
    ctaText="Schedule a Demo"
    ctaLink="/BubblesCorpDemo/contact"
    backgroundImage="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=1200&h=600&fit=crop"
  />

  <section class="py-20 md:py-28 section-gradient">
    <div class="page-container">
      <AnimatedStats client:load stats={[
        { value: 500, label: "Expert SAP Professionals", suffix: "+" },
        { value: 98, label: "Client Satisfaction Rate", suffix: "%" },
        { value: 15, label: "Years of Excellence", suffix: "+" },
        { value: 100, label: "Successful Implementations", suffix: "+" }
      ]} />
    </div>
  </section>

  <ScrollRevealSection client:visible variant="glass">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold mb-4" style="color: var(--color-text);">Why Choose BubbleCorp?</h2>
      <p class="text-lg max-w-xl mx-auto" style="color: var(--color-text-secondary);">Industry expertise, proven solutions, and dedicated support</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <GlowCard client:visible icon={iconTarget} title="Expert Implementation" description="Leveraging years of SAP expertise to deliver seamless implementations tailored to your business needs." delay={0} />
      <GlowCard client:visible icon={iconZap} title="Fast Deployment" description="Accelerated timelines without compromising quality. Get your SAP systems running efficiently." delay={0.1} />
      <GlowCard client:visible icon={iconShield} title="Enterprise Security" description="Robust security protocols ensuring your financial data is protected with industry best practices." delay={0.2} />
      <GlowCard client:visible icon={iconHandshake} title="24/7 Support" description="Dedicated support team available round-the-clock to ensure your systems run smoothly." delay={0.3} />
      <GlowCard client:visible icon={iconTrending} title="Performance Optimization" description="Continuous monitoring and optimization to maximize your SAP system performance and ROI." delay={0.4} />
      <GlowCard client:visible icon={iconGrad} title="Training & Knowledge Transfer" description="Comprehensive training programs ensuring your team masters the systems and tools." delay={0.5} />
    </div>
  </ScrollRevealSection>

  <ScrollRevealSection client:visible variant="gradient">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold mb-4" style="color: var(--color-text);">Our Services</h2>
      <p class="text-lg max-w-xl mx-auto" style="color: var(--color-text-secondary);">Comprehensive SAP Group Reporting solutions for every stage of your journey</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 mb-12">
      <GlowCard client:visible icon={iconWrench} title="Implementation" description="End-to-end SAP Group Reporting implementation with best practices, data migration, and system configuration." delay={0} />
      <GlowCard client:visible icon={iconSettings} title="Optimization" description="Performance tuning, process optimization, and system enhancement to maximize your investment." delay={0.1} />
      <GlowCard client:visible icon={iconBarChart} title="Reporting Solutions" description="Advanced reporting, consolidation, and analytics solutions for better business insights." delay={0.2} />
      <GlowCard client:visible icon={iconBook} title="Training & Support" description="Comprehensive training programs and ongoing technical support for your team." delay={0.3} />
    </div>
    <div class="text-center">
      <MagneticButton client:load href="/BubblesCorpDemo/services" className="btn-gradient">
        Explore All Services
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </MagneticButton>
    </div>
  </ScrollRevealSection>

  <ScrollRevealSection client:visible variant="glass">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-4xl font-bold mb-4" style="color: var(--color-text);">Ready to Transform Your SAP Strategy?</h2>
      <p class="text-lg mb-8" style="color: var(--color-text-secondary);">Let's discuss how BubbleCorp can help you achieve your business goals with advanced SAP solutions.</p>
      <MagneticButton client:load href="/BubblesCorpDemo/contact" className="btn-gradient">
        Get Started Today
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </MagneticButton>
    </div>
  </ScrollRevealSection>

  <Footer />
</MainLayout>
