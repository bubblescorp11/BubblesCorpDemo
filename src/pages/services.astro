---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ParallaxHero from '../components/react/ParallaxHero.tsx';
import ScrollRevealSection from '../components/react/ScrollRevealSection.tsx';
import GlowCard from '../components/react/GlowCard.tsx';
import TimelineStep from '../components/react/TimelineStep.tsx';
import MagneticButton from '../components/react/MagneticButton.tsx';
import { iconWrench, iconSettings, iconBarChart, iconBook, iconArrow } from '../components/react/icons';
---

<MainLayout title="SAP Services - BubbleCorp" description="Comprehensive SAP Group Reporting services including implementation, optimization, training, and support.">
  <Navbar currentPath="/BubblesCorpDemo/services" />

  <ParallaxHero
    client:load
    title="Our SAP Services"
    subtitle="Complete Solutions"
    description="End-to-end SAP Group Reporting solutions tailored to your business requirements"
    backgroundImage="https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1200&h=600&fit=crop"
  />

  <ScrollRevealSection client:visible variant="default">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold mb-4" style="color: var(--color-text);">What We Offer</h2>
      <p class="text-lg max-w-xl mx-auto" style="color: var(--color-text-secondary);">Comprehensive SAP solutions for every aspect of your financial operations</p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <GlowCard client:visible icon={iconWrench} title="SAP Group Reporting Implementation" description="End-to-end implementation of SAP Group Reporting systems tailored to your organization's unique requirements. Our expert team handles system configuration, data migration, and integration." delay={0} />
      <GlowCard client:visible icon={iconSettings} title="Performance Optimization & Support" description="Maximize the efficiency and performance of your SAP systems. We provide continuous monitoring, proactive maintenance, and optimization strategies." delay={0.1} />
      <GlowCard client:visible icon={iconBarChart} title="Advanced Reporting & Analytics" description="Transform your data into actionable insights with advanced reporting and analytics solutions. Custom dashboards and deep financial visibility." delay={0.2} />
      <GlowCard client:visible icon={iconBook} title="Training & Knowledge Transfer" description="Empower your team with comprehensive training and knowledge transfer programs. Customized materials to ensure effective SAP system management." delay={0.3} />
      <GlowCard client:visible icon={iconSettings} title="Financial Consolidation Solutions" description="Streamline your financial consolidation processes with sophisticated SAP solutions. Improved accuracy and accelerated close procedures." delay={0.4} />
      <GlowCard client:visible icon={iconSettings} title="Managed Services & Support" description="Outsource your SAP system management to our experienced team. 24/7 monitoring, maintenance, and support for optimal performance." delay={0.5} />
    </div>
  </ScrollRevealSection>

  <ScrollRevealSection client:visible variant="gradient">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold mb-4" style="color: var(--color-text);">Our Approach</h2>
      <p class="text-lg max-w-xl mx-auto" style="color: var(--color-text-secondary);">A proven methodology for successful implementations</p>
    </div>
    <div class="max-w-lg mx-auto">
      <TimelineStep client:visible step={1} title="Assessment" description="We conduct a thorough assessment of your current systems and requirements." delay={0} />
      <TimelineStep client:visible step={2} title="Planning" description="Develop a comprehensive project plan and implementation roadmap." delay={0.1} />
      <TimelineStep client:visible step={3} title="Implementation" description="Execute the implementation with rigorous quality assurance." delay={0.2} />
      <TimelineStep client:visible step={4} title="Deployment" description="Go-live support and system stabilization in production." delay={0.3} />
      <TimelineStep client:visible step={5} title="Support" description="Ongoing monitoring, maintenance, and optimization support." isLast={true} delay={0.4} />
    </div>
  </ScrollRevealSection>

  <ScrollRevealSection client:visible variant="glass">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-4xl font-bold mb-4" style="color: var(--color-text);">Ready to Optimize Your SAP Systems?</h2>
      <p class="text-lg mb-8" style="color: var(--color-text-secondary);">Contact our team to discuss which services are right for your organization.</p>
      <MagneticButton client:load href="/BubblesCorpDemo/contact" className="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-bold text-white text-lg shadow-lg" style="background:linear-gradient(135deg, var(--color-accent), var(--color-accent-secondary)); box-shadow: 0 4px 24px var(--color-accent-glow);">
        Request a Consultation
        {iconArrow}
      </MagneticButton>
    </div>
  </ScrollRevealSection>

  <Footer />
</MainLayout>
